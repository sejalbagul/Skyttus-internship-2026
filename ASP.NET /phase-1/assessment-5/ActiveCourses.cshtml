@model List<EduManage.Models.Course>

@{
    ViewData["Title"] = "Active Courses";
}

<div class="container">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="Course" asp-action="Index">Courses</a></li>
            <li class="breadcrumb-item active">Active Courses</li>
        </ol>
    </nav>

    <div class="row mb-4">
        <div class="col-12">
            <h1 class="display-5">
                <i class="fas fa-check-circle text-success"></i> Active Courses
            </h1>
            <p class="lead">Currently running and upcoming courses</p>
            <hr />
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning">
            <i class="fas fa-exclamation-triangle"></i> No active courses found.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var course in Model)
            {
                @await Html.PartialAsync("_CourseCard", course)
            }
        </div>
    }

    <div class="row mt-4">
        <div class="col-12 text-center">
            <a asp-controller="Course" asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to All Courses
            </a>
        </div>
    </div>
</div>