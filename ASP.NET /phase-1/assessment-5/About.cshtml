@{
    ViewData["Title"] = "About";
}

<div class="container">
    <h1 class="display-5">@ViewData["Title"]</h1>
    <p class="lead">@ViewData["Message"]</p>

    <div class="row mt-4">
        <div class="col-md-8">
            <h3>About EduManage</h3>
            <p>@ViewData["Description"]</p>

            <h4 class="mt-4">Features Implemented:</h4>
            <ul>
                <li>✅ MVC Pattern with Controllers, Models, and Views</li>
                <li>✅ Strongly typed views with Razor syntax</li>
                <li>✅ Shared layout for consistent UI</li>
                <li>✅ Partial views for reusable components</li>
                <li>✅ Bootstrap 5 for responsive design</li>
            </ul>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Technologies Used</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled">
                        <li class="mb-2">✓ ASP.NET Core 8.0</li>
                        <li class="mb-2">✓ C#</li>
                        <li class="mb-2">✓ Bootstrap 5</li>
                        <li class="mb-2">✓ Font Awesome</li>
                        <li class="mb-2">✓ Razor Views</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>