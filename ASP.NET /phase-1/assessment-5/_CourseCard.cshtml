@model EduManage.Models.Course

<div class="col-md-4 mb-4">
    <div class="card h-100 shadow-sm">
        <div class="card-header @(Model.IsActive ? "bg-success" : "bg-secondary") text-white">
            <h5 class="card-title mb-0">
                <i class="fas fa-book"></i> @Model.CourseCode
            </h5>
        </div>
        <div class="card-body">
            <h6 class="card-subtitle mb-3">@Model.CourseName</h6>
            
            <ul class="list-unstyled">
                <li class="mb-2">
                    <i class="fas fa-user-tie text-success me-2"></i>
                    <strong>Instructor:</strong> @Model.Instructor
                </li>
                <li class="mb-2">
                    <i class="fas fa-layer-group text-success me-2"></i>
                    <strong>Credits:</strong> @Model.Credits
                </li>
                <li class="mb-2">
                    <i class="fas fa-clock text-success me-2"></i>
                    <strong>Duration:</strong> @Model.DurationInWeeks weeks
                </li>
                <li class="mb-2">
                    <i class="fas fa-calendar text-success me-2"></i>
                    <strong>Starts:</strong> @Model.StartDate.ToString("dd MMM yyyy")
                </li>
                <li class="mb-2">
                    <i class="fas fa-tag text-success me-2"></i>
                    <strong>Fee:</strong> ₹ @Model.Fee.ToString("N0")
                </li>
            </ul>

            <div class="d-flex justify-content-between align-items-center mt-3">
                <span class="badge bg-info">@Model.Department</span>
                <a asp-controller="Course" asp-action="Details" asp-route-id="@Model.Id" 
                   class="btn btn-sm btn-outline-success">
                    Details <i class="fas fa-arrow-right"></i>
                </a>
            </div>
        </div>
        @if (Model.IsActive)
        {
            <div class="card-footer bg-light">
                <small class="text-success">
                    <i class="fas fa-check-circle"></i> Active Course
                </small>
            </div>
        }
    </div>
</div>