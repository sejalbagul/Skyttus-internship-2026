@{
    ViewData["Title"] = "Home";
}

<div class="text-center">
    <div class="jumbotron bg-light p-5 rounded-3 mb-4">
        <h1 class="display-4">
            <i class="fas fa-graduation-cap text-success"></i> Welcome to EduManage
        </h1>
        <p class="lead">Your comprehensive education management solution</p>
        <hr class="my-4">
        <p>Manage courses, instructors, and students efficiently</p>
        <a class="btn btn-success btn-lg" asp-controller="Course" asp-action="Index" role="button">
            <i class="fas fa-book-open"></i> Browse Courses
        </a>
    </div>

    <div class="row mt-5">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <i class="fas fa-book fa-3x text-success mb-3"></i>
                    <h5 class="card-title">Courses</h5>
                    <p class="card-text">Browse our extensive catalog of courses</p>
                    <a asp-controller="Course" asp-action="Index" class="btn btn-outline-success">View Courses</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <i class="fas fa-check-circle fa-3x text-success mb-3"></i>
                    <h5 class="card-title">Active Courses</h5>
                    <p class="card-text">See currently running courses</p>
                    <a asp-controller="Course" asp-action="ActiveCourses" class="btn btn-outline-success">View Active</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <i class="fas fa-building fa-3x text-success mb-3"></i>
                    <h5 class="card-title">Departments</h5>
                    <p class="card-text">Filter courses by department</p>
                    <div class="btn-group">
                        <a asp-controller="Course" asp-action="ByDepartment" asp-route-department="Computer Science" class="btn btn-outline-success btn-sm">CS</a>
                        <a asp-controller="Course" asp-action="ByDepartment" asp-route-department="Mathematics" class="btn btn-outline-success btn-sm">Math</a>
                        <a asp-controller="Course" asp-action="ByDepartment" asp-route-department="Physics" class="btn btn-outline-success btn-sm">Physics</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- MVC Pattern Info -->
    <div class="row mt-5">
        <div class="col-12">
            <div class="alert alert-success">
                <strong>✓ MVC Pattern Implemented:</strong> Controllers, Models, Views, Strongly Typed Views, Shared Layout, Partial Views
            </div>
        </div>
    </div>
</div>