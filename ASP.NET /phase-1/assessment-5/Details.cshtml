@model EduManage.Models.Course

@{
    ViewData["Title"] = "Course Details";
}

<div class="container">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="Course" asp-action="Index">Courses</a></li>
            <li class="breadcrumb-item active">@Model.CourseName</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h3 class="mb-0">@Model.CourseName</h3>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h5>Course Code</h5>
                            <p class="text-muted">@Model.CourseCode</p>
                        </div>
                        <div class="col-md-6">
                            <h5>Credits</h5>
                            <p class="text-muted">@Model.Credits credits</p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h5>Department</h5>
                            <p class="text-muted">@Model.Department</p>
                        </div>
                        <div class="col-md-6">
                            <h5>Instructor</h5>
                            <p class="text-muted">@Model.Instructor</p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h5>Duration</h5>
                            <p class="text-muted">@Model.DurationInWeeks weeks</p>
                        </div>
                        <div class="col-md-6">
                            <h5>Start Date</h5>
                            <p class="text-muted">@Model.StartDate.ToString("MMMM dd, yyyy")</p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h5>Fee</h5>
                            <p class="text-success h4">₹ @Model.Fee.ToString("N0")</p>
                        </div>
                        <div class="col-md-6">
                            <h5>Status</h5>
                            @if (Model.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactive</span>
                            }
                        </div>
                    </div>
                </div>
                <div class="card-footer">
                    <a asp-controller="Course" asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back to List
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">Quick Info</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled">
                        <li class="mb-2"><i class="fas fa-calendar text-success"></i> Starts: @Model.StartDate.ToString("dd MMM yyyy")</li>
                        <li class="mb-2"><i class="fas fa-clock text-success"></i> Duration: @Model.DurationInWeeks weeks</li>
                        <li class="mb-2"><i class="fas fa-tag text-success"></i> Credits: @Model.Credits</li>
                        <li class="mb-2"><i class="fas fa-user text-success"></i> Instructor: @Model.Instructor</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>