@{
    ViewData["Title"] = "Contact Us";
}

<div class="container">
    <h1 class="display-5">@ViewData["Title"]</h1>
    <p class="lead">Get in touch with us</p>

    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Contact Information</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled">
                        <li class="mb-3">
                            <i class="fas fa-map-marker-alt text-success fa-lg me-2"></i>
                            <strong>Address:</strong><br>
                            123 Education Street, Knowledge Park, New Delhi - 110001
                        </li>
                        <li class="mb-3">
                            <i class="fas fa-phone text-success fa-lg me-2"></i>
                            <strong>Phone:</strong><br>
                            +91 11 2345 6789
                        </li>
                        <li class="mb-3">
                            <i class="fas fa-envelope text-success fa-lg me-2"></i>
                            <strong>Email:</strong><br>
                            info@edumanage.edu.in
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Send us a Message</h5>
                </div>
                <div class="card-body">
                    <form>
                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <input type="text" class="form-control" placeholder="Your name">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" placeholder="your.email@example.com">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Message</label>
                            <textarea class="form-control" rows="4" placeholder="Your message..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-paper-plane"></i> Send Message
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>