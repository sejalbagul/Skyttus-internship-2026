@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container">
    <h1 class="display-5">@ViewData["Title"]</h1>
    <p>Last updated: @DateTime.Now.ToString("MMMM dd, yyyy")</p>
    
    <div class="mt-4">
        <h3>Information Collection</h3>
        <p>We collect student information necessary for academic management including name, contact details, and academic records.</p>
        
        <h3>Information Usage</h3>
        <p>Student data is used solely for educational purposes, performance tracking, and communication.</p>
        
        <h3>Data Protection</h3>
        <p>All data is stored securely and accessed only by authorized personnel.</p>
    </div>
</div>