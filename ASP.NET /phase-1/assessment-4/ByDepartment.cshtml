@model List<EduManage.Models.Course>

@{
    string departmentName = ViewBag.DepartmentName ?? "Department";
    ViewData["Title"] = $"{departmentName} Courses";
}

<div class="container">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="Course" asp-action="Index">Courses</a></li>
            <li class="breadcrumb-item active">@departmentName</li>
        </ol>
    </nav>

    <div class="row mb-4">
        <div class="col-12">
            <h1 class="display-5">
                <i class="fas fa-building text-primary"></i> @departmentName Department
            </h1>
            <p class="lead">Courses offered in @departmentName</p>
            <hr />
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center py-5">
            <i class="fas fa-info-circle fa-3x mb-3"></i>
            <h4>No Courses Found</h4>
            <p>There are currently no courses available in the @departmentName department.</p>
            <a asp-controller="Course" asp-action="Index" class="btn btn-primary mt-3">
                <i class="fas fa-arrow-left"></i> Back to All Courses
            </a>
        </div>
    }
    else
    {
        <!-- Statistics -->
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="card text-white bg-primary">
                    <div class="card-body">
                        <h5>Total Courses</h5>
                        <h2>@Model.Count</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-white bg-success">
                    <div class="card-body">
                        <h5>Active Courses</h5>
                        <h2>@Model.Count(c => c.IsActive)</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-white bg-info">
                    <div class="card-body">
                        <h5>Total Credits</h5>
                        <h2>@Model.Sum(c => c.Credits)</h2>
                    </div>
                </div>
            </div>
        </div>

        <!-- Courses Grid using Partial View -->
        <div class="row">
            @foreach (var course in Model)
            {
                @await Html.PartialAsync("_CourseCard", course)
            }
        </div>
    }
</div>